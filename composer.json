{
    "name": "homm/hommform",
    "description": "Submit and view forms",
    "type": "craft-plugin",
    "version": "4.0.0-rc4",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "hommform",
        "form",
        "form viewer"
    ],
    "support": {
        "docs": "https://github.com/HOMMinteractive/hommform/blob/master/README.md",
        "issues": "https://github.com/HOMMinteractive/hommform/issues"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Benjamin Ammann",
            "homepage": "https://github.com/ammannbe"
        }
    ],
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0.0",
        "ext-json": "*",
        "ext-fileinfo": "*"
    },
    "autoload": {
        "psr-4": {
          "homm\\hommform\\": "src/"
        }
    },
    "extra": {
        "name": "HOMM Form",
        "handle": "hommform",
        "developer": "HOMM interactive",
        "developerUrl": "https://github.com/HOMMinteractive",
        "documentationUrl": "https://github.com/HOMMinteractive/hommform/blob/master/README.md",
        "changelogUrl": "https://raw.githubusercontent.com/HOMMinteractive/hommform/master/CHANGELOG.md",
        "class": "homm\\hommform\\HOMMForm"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    }
}

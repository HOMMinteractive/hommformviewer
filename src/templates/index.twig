{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% do view.registerAssetBundle("homm\\hommformviewer\\assetbundles\\hommformviewercp\\HOMMFormViewerCPAsset") %}

{# The title of this CP section #}
{% set title = "Form requests"|t('hommformviewer') %}

{% set forms = craft.hommformviewer.forms %}
{% set formId = craft.app.request.getParam('formId') %}

{% if not formId and forms|length %}
    {% redirect cpUrl('hommformviewer', { formId: forms[0] }) 302 %}
{% endif %}


{# Content that should appear in the page header #}
{% block actionButton  %}
    <input class="text search hommformviewer_search" placeholder="{{ 'Search'|t('hommformviewer') }}">

    <div class="buttons">
        <a href="{{ cpUrl('hommformviewer/export', { formId }) }}" class="btn">{{ 'Export...'|t('hommformviewer') }}</a>
        &nbsp;
        <form action="{{ cpUrl('hommformviewer/delete') }}" method="post" onsubmit="return confirm('{{ 'Do you really want to delete this form and all its data?\\nThis action cannot be undone.'|t('hommformviewer') }}');">
            {{ csrfInput() }}
            {{ redirectInput('hommformviewer') }}

            <input type="hidden" name="form" value="{{ formId }}">
            <button class="btn submit">{{ 'Delete'|t('hommformviewer') }}</button>
        </form>
    </div>
{% endblock %}

{% set sidebar %}
    <nav class="hommformviewer_nav">
        <ul>
            {% for fId in forms %}
                <li>
                    <a href="{{ cpUrl('hommformviewer', { formId: fId }) }}" class="{{ formId == fId ? 'sel' }}">
                        <span class="label">{{ fId }}</span>
                    </a>
                </li>
            {% endfor %}
        </ul>
    </nav>
{% endset %}

{# The content of the CP Section #}
{% set content %}
    {% if formId %}
        {% set entries = craft.hommformviewer.entries(formId) %}

        <div class="hommformviewer__table">
            <table class="data">
                <thead>
                    <tr>
                        {% for item in entries[:1]|first %}
                            <th>{{ item }}</th>
                        {% endfor %}
                    </tr>
                </thead>

                <tbody>
                    {% for row in entries[1:]|reverse %}
                        <tr>
                            {% for item in row %}
                                <td>
                                    {% if item.folder is defined and item.name is defined %}
                                        <a href="{{ cpUrl('hommformviewer/download/' ~ item.folder ~ '/' ~ item.name) }}" target="_blank" title="{{ item.name }}" class="table-item">{{ item.name }}</a>
                                    {% elseif item is array %}
                                        {% for value in item|map(v => v is array ? v : [v]) %}
                                            {{ value|join(', ') }}<br>
                                        {% endfor %}
                                    {% elseif 'http://' in item or 'https://' in item %}
                                        <a href="{{ item }}" target="_blank" title="{{ item }}" class="table-item">{{ item }}</a>
                                    {% elseif item|first == '@' %}
                                        <a href="{{ alias(item) }}" target="_blank" title="{{ alias(item) }}" class="table-item">{{ alias(item) }}</a>
                                    {% else %}
                                        <span title="{{ item }}" class="table-item">{{ item }}</span>
                                    {% endif %}
                                </td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="hommformviewer__total">
            <strong>{{ 'Total: {count} entries'|t('hommformviewer', { count: entries[1:]|length }) }}</strong>
        </div>
    {% else %}
        <p>{{ 'No entries available.'|t('hommformviewer') }}</p>
    {% endif %}
{% endset %}

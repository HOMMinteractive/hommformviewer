{% import "_includes/forms" as forms %}

{{ forms.autosuggestField({
    label: 'Storage path for attachments'|t('hommformviewer'),
    id: 'storagePath',
    name: 'storagePath',
    value: settings['storagePath'],
    suggestAliases: true,
    suggestEnvVars: true,
}) }}

{{ forms.autosuggestField({
    label: 'Recaptcha Site Key'|t('hommformviewer'),
    id: 'recaptchaSiteKey',
    name: 'recaptchaSiteKey',
    value: settings['recaptchaSiteKey'],
    suggestEnvVars: true,
}) }}

{{ forms.autosuggestField({
    label: 'Recaptcha Secret'|t('hommformviewer'),
    id: 'recaptchaSecret',
    name: 'recaptchaSecret',
    value: settings['recaptchaSecret'],
    suggestEnvVars: true,
}) }}

{{ forms.rangeField({
    label: 'Recaptcha Score Threshold'|t('hommformviewer'),
    id: 'recaptchaScoreThreshold',
    name: 'recaptchaScoreThreshold',
    value: settings['recaptchaScoreThreshold'] ?? 0.5,
    min: 0,
    max: 1,
    step: 0.1,
    instructions: 'The higher the value, the stricter the spam protection. A common default is 0.5.'|t('hommformviewer'),
}) }}
